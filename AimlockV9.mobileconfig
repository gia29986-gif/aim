				<key>AuthenticationMethod</key>
				<string>SharedSecret</string>
				<key>RemoteAddress</key>
				<string>v9.aimlock.com</string>
				<key>SharedSecret</key>
				<data>VjlBbWxvY2tTZWNyZXQ=</data>
			</dict>
			<key>VPNType</key>
			<string>IKEv2</string>
		</dict>

		<!-- (3) Wi-Fi Enterprise Settings - High Priority Traffic -->
		<dict>
			<key>AutoJoin</key>
			<true/>
			<key>CaptiveBypass</key>
			<true/>
			<key>HIDDEN_NETWORK</key>
			<false/>
