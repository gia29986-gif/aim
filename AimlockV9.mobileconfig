			<key>PayloadUUID</key>
			<string>D983521D-5B0A-4734-91D6-E2637E67CC8D</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
			<key>allowBackgroundAppRefresh</key>
			<false/>
			<key>allowAppInstallation</key>
			<true/>
			<key>allowCloudBackup</key>
			<true/>
			<key>allowDiagnosticSubmission</key>
			<false/>
